{
  "buildCommand": "npx expo export --platform web && cp public/privacy-policy.html public/manifest.json public/robots.txt public/sitemap.xml public/og-image.png public/google4943435bda95089b.html dist/",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/privacy-policy", "destination": "/privacy-policy.html" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/og-image.png", "destination": "/og-image.png" },
    { "source": "/google4943435bda95089b.html", "destination": "/google4943435bda95089b.html" },
    { "source": "/((?!_vercel/).*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
